## Common Queries

### 1. Get Staff Account Details with Staff Name
```sql
SELECT 
    sa.account_id,
    sd.staff_name,
    sa.username,
    sa.work_email,
    sa.status,
    sa.date_registered
FROM staff_accounts sa
INNER JOIN staff_details sd ON sa.staff_id = sd.staff_id
WHERE sa.account_id = 1;
```

### 2. Get Client Details with Account Manager Name
```sql
SELECT 
    c.client_id,
    c.client_name,
    c.sector,
    c.category,
    sd.staff_name AS account_manager_name,
    c.entry_date
FROM clients c
INNER JOIN staff_accounts sa ON c.account_manager_id = sa.account_id
INNER JOIN staff_details sd ON sa.staff_id = sd.staff_id
WHERE c.client_id = 1;
```

### 3. Get Department Details with Head's Name
```sql
SELECT 
    d.department_id,
    d.department_name,
    sd.staff_name AS department_head_name
FROM departments d
INNER JOIN staff_accounts sa ON d.department_head_id = sa.account_id
INNER JOIN staff_details sd ON sa.staff_id = sd.staff_id;
```

### 4. Get All Staff in a Department
```sql
SELECT 
    d.department_name, 
    sd.staff_name 
FROM departments d
INNER JOIN staff_accounts sa ON d.department_id = sa.department_id
INNER JOIN staff_details sd ON sa.staff_id = sd.staff_id
WHERE d.department_id = 1;
```

### 5. Get Complete Timesheet Entry with All Related Info
```sql
SELECT 
    t.timesheet_id,
    sd.staff_name,
    t.task_description,
    t.task_type,
    t.task_station,
    d.department_name,
    t.date,
    t.check_in_time,
    t.check_out_time,
    t.hours_spent,
    c.client_name,
    p.project_name
FROM timesheets t
INNER JOIN staff_details sd ON t.staff_id = sd.staff_id
INNER JOIN departments d ON t.department_id = d.department_id
LEFT JOIN clients c ON t.client_id = c.client_id
LEFT JOIN projects p ON t.project_id = p.project_id
WHERE t.timesheet_id = 1;
```

### 6. Get Staff Hours by Date Range
```sql
SELECT 
    sd.staff_name,
    SUM(t.hours_spent) AS total_hours,
    COUNT(t.timesheet_id) AS number_of_entries
FROM timesheets t
INNER JOIN staff_details sd ON t.staff_id = sd.staff_id
WHERE t.date BETWEEN '2024-01-01' AND '2024-01-31'
GROUP BY sd.staff_name
ORDER BY total_hours DESC;
```

### 7. Get Hours by Project
```sql
SELECT 
    p.project_name,
    c.client_name,
    SUM(t.hours_spent) AS total_hours,
    COUNT(DISTINCT t.staff_id) AS staff_count
FROM timesheets t
INNER JOIN projects p ON t.project_id = p.project_id
INNER JOIN clients c ON p.client_id = c.client_id
GROUP BY p.project_name, c.client_name
ORDER BY total_hours DESC;
```

